# Шаблон конфигурации MIRAGE.
# Скопируй в keys.env и заполни своими значениями:  cp keys.env.example keys.env
# (keys.env в .gitignore и НЕ попадает в репозиторий.)
#
# Сгенерировать ключи:  ./bin/mirage genkey   (запусти дважды — серверу и клиенту)

# Ключи сервера
SERVER_PRIV=<base64url приватного ключа сервера>
SERVER_PUB=<base64url публичного ключа сервера>

# Ключи клиента
CLIENT_PRIV=<base64url приватного ключа клиента>
CLIENT_PUB=<base64url публичного ключа клиента>

# Адрес сервера (UDP-профиль)
ENDPOINT=YOUR_SERVER_IP:5555

# Reality-профиль (опционально)
REALITY_PSK=<base64url, 32 байта>
REALITY_ENDPOINT=YOUR_SERVER_IP:443
REALITY_SNI=www.example.com
REALITY_DEST=www.example.com:443
